{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=49152",
      "AIPIFY_SPLIT_BUILD": "0",
      "AIPIFY_BUILD_HEAP_COMPILE": "--max-old-space-size=14336",
      "AIPIFY_BUILD_HEAP_GENERATE": "--max-old-space-size=8192"
    }
  }
}

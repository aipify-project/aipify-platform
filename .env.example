NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Customer APP origin — development only (production always uses https://app.aipify.ai for auth emails)
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# Optional server override for auth email redirects (must not be localhost in production)
# AUTH_APP_ORIGIN=https://app.aipify.ai
# Required for sign-in verification (2FA). Generate: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=

# P1.01 — Live authenticated APP E2E certification (optional; never commit credentials)
# APP_LIVE_E2E_ENABLED=1
# APP_LIVE_E2E_ENVIRONMENT=staging
# APP_LIVE_E2E_EMAIL=
# APP_LIVE_E2E_PASSWORD=
# APP_LIVE_E2E_BASE_URL=https://app.aipify.ai
# APP_LIVE_E2E_ISOLATION_EMAIL=
# APP_LIVE_E2E_ISOLATION_PASSWORD=
# APP_LIVE_E2E_ORGANIZATION_REF=

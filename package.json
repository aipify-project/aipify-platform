{
  "name": "aipify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001 --webpack",
    "build": "next build --webpack",
    "typecheck": "tsc --noEmit",
    "validate:phase": "npm run lint && npm run typecheck",
    "start": "next start",
    "lint": "eslint",
    "test:greeting": "npx --yes tsx lib/core/greeting.test.ts",
    "test:intelligence": "npx --yes tsx lib/intelligence/router.test.ts",
    "generate:aipify-loader": "node scripts/generate-aipify-loader-assets.mjs",
    "supabase:link": "npx supabase link --project-ref qbcqoixhrvhnuwphefvw",
    "supabase:sql": "node scripts/supabase-apply-sql.mjs list",
    "supabase:sql:apply": "node scripts/supabase-apply-sql.mjs apply",
    "supabase:sql:exec": "node scripts/supabase-apply-sql.mjs exec",
    "supabase:push": "node scripts/push-supabase-migrations.cjs",
    "supabase:push:dry": "node scripts/push-supabase-migrations.cjs --dry-run",
    "supabase:apply-batches": "node scripts/apply-migration-batches-pg.cjs",
    "supabase:apply-all": "node scripts/supabase-apply-sql.mjs apply",
    "supabase:apply-remote": "node scripts/apply-all-pending-remote.mjs",
    "supabase:apply-pending": "node scripts/apply-all-migrations-mcp-style.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "lottie-web": "^5.13.0",
    "next": "16.2.9",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "gifenc": "^1.0.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
